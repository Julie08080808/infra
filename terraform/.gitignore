# Terraform local working directory
.terraform/

# Terraform state files - may contain sensitive data
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.*

# Terraform variable files - may contain secrets
*.tfvars
terraform.tfvars
!terraform.tfvars.example

# Terraform plan / crash files
*.tfplan
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
